# contact-gated extraction rules for the inverter example
active: 1/0
poly:   2/0
nwell:  3/0
conn:   1/0, 2/0, 3/0, 5/0
contact: 6/0 1/0 5/0    # diff  <-> met1
contact: 6/0 2/0 5/0    # poly  <-> met1
contact: 9/0 3/0 5/0    # nwell <-> met1 (well tap)
label:  8/0
substrate: VSS
nfet:   nfet
pfet:   pfet
